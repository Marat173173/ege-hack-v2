# ============================================================
# Переменные окружения ЕГЭ-ХАК
# Скопируй в .env.local для локальной разработки.
# На Railway — вкладка Variables (БД подставится автоматически).
# ============================================================

# PostgreSQL (Railway подставит автоматически при подключении БД)
DATABASE_URL="postgresql://user:password@localhost:5432/egehack?schema=public"

# NextAuth
NEXTAUTH_SECRET="сгенерируй-случайную-строку-32-символа"
NEXTAUTH_URL="http://localhost:3000"

# Google OAuth (необязательно — раскомментируй, если нужен вход через Google)
# GOOGLE_CLIENT_ID=""
# GOOGLE_CLIENT_SECRET=""
