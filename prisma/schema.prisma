// ============================================================
// Prisma-схема ЕГЭ-ХАК
// PostgreSQL · NextAuth · профиль · геймификация · прогресс
// ============================================================

generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider   = "postgresql"
  url        = env("DATABASE_URL")
  extensions = [vector]
}

// ————————————————————————————————————————————————
// 1. Аутентификация (NextAuth.js Prisma Adapter)
// ————————————————————————————————————————————————

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  name          String?
  passwordHash  String?   // null если вход через OAuth
  emailVerified DateTime?
  image         String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  accounts Account[]
  sessions Session[]
  profile  Profile?
  game     GameState?
  progress TopicProgress[]
  chats    ChatSession[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ————————————————————————————————————————————————
// 2. Профиль пользователя
// ————————————————————————————————————————————————

model Profile {
  id          String  @id @default(cuid())
  userId      String  @unique
  user        User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  name        String  @default("Ученик")
  avatarEmoji String  @default("🦊")
  avatarHue   Int     @default(38)
  targetScore Int     @default(80)
  examDate    String? // YYYY-MM-DD
  viewMode    String  @default("spire") // "spire" | "path"
  viewChosen  Boolean @default(false)
  sound       Boolean @default(true)

  // уведомления (JSON проще, чем 4 отдельные колонки)
  notify      Json    @default("{\"daily\":true,\"streakRisk\":true,\"weekly\":true,\"parent\":false}")

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// ————————————————————————————————————————————————
// 3. Геймификация
// ————————————————————————————————————————————————

model GameState {
  id            String  @id @default(cuid())
  userId        String  @unique
  user          User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  xp            Int     @default(0)
  dailyXp       Int     @default(0)
  dailyGoal     Int     @default(50)
  streak        Int     @default(0)
  lastActiveDay String? // YYYY-MM-DD
  combo         Int     @default(0)
  bestCombo     Int     @default(0)

  updatedAt     DateTime @updatedAt
}

// ————————————————————————————————————————————————
// 4. Прогресс по темам (этажам Шпиля)
// ————————————————————————————————————————————————

model TopicProgress {
  id        String @id @default(cuid())
  userId    String
  user      User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  topicId   String // "rus-orf", "math-alg", …
  prog      Int    @default(0) // освоение 0..100
  stab      Int    @default(0) // стабильность 0..100

  updatedAt DateTime @updatedAt

  @@unique([userId, topicId])
  @@index([userId])
}

// ————————————————————————————————————————————————
// 5. Каталог заданий ЕГЭ/ОГЭ
// ————————————————————————————————————————————————

model Task {
  id          String   @id @default(cuid())
  topicId     String   // привязка к теме ("rus-orf", "math-alg")
  exam        String   // "ege" | "oge"
  title       String
  body        String   @db.Text
  answer      String?  @db.Text
  explanation String?  @db.Text
  difficulty  Int      @default(1) // 1-3
  tags        String[] @default([])

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([topicId])
  @@index([exam])
}
// ————————————————————————————————————————————————
// 6. RAG: база знаний для ИИ-репетитора
// ————————————————————————————————————————————————

model KnowledgeChunk {
  id        String                       @id @default(cuid())
  subject   String                       // "russian", "math", "social", …
  topicId   String?                      // привязка к теме из registry.ts
  topicCode String?                      // код из кодификатора ФИПИ, например "1.1.3"
  kind      String                       // "rule" | "example" | "mistake" | "definition"
  source    String                       // источник: "fipi-codifier" | "claude-generated" | "manual"
  title     String
  text      String                       @db.Text
  embedding Unsupported("vector(384)")?  // 384 для MiniLM (локальные эмбеддинги)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([subject])
  @@index([topicId])
  @@index([topicCode])
}

// ————————————————————————————————————————————————
// 7. История чата с ИИ-репетитором
// ————————————————————————————————————————————————

model ChatSession {
  id        String        @id @default(cuid())
  userId    String
  user      User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  title     String        @default("Новый разговор")
  subject   String?       // если разговор привязан к предмету
  messages  ChatMessage[]
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt

  @@index([userId])
}

model ChatMessage {
  id          String      @id @default(cuid())
  sessionId   String
  session     ChatSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  role        String      // "user" | "assistant"
  content     String      @db.Text
  // ID использованных при ответе чанков (для отладки и улучшения)
  citedChunks String[]    @default([])
  createdAt   DateTime    @default(now())

  @@index([sessionId])
}
